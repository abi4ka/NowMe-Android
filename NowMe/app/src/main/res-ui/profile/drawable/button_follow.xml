<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/nowme_surface_soft" />
            <stroke
                android:width="1dp"
                android:color="@color/nowme_text_muted" />
            <corners android:radius="@dimen/nowme_radius_lg" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/nowme_surface_overlay_pressed" />
            <stroke
                android:width="1dp"
                android:color="@color/nowme_text_primary" />
            <corners android:radius="@dimen/nowme_radius_lg" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/nowme_surface_soft" />
            <stroke
                android:width="1dp"
                android:color="@color/nowme_text_primary" />
            <corners android:radius="@dimen/nowme_radius_lg" />
        </shape>
    </item>
</selector>
