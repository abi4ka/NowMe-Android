<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_nowme_visibility_menu"
    android:orientation="vertical"
    android:padding="@dimen/nowme_space_xs">

    <TextView
        android:id="@+id/btnPinNowme"
        style="@style/Text.NowMe.Body"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_nowme_visibility_menu_item"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/nowme_space_md"
        android:textColor="@color/nowme_text_primary"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="@dimen/nowme_space_sm"
        android:layout_marginVertical="@dimen/nowme_space_xs"
        android:background="@color/nowme_surface_overlay" />

    <TextView
        android:id="@+id/btnVisibilityAction"
        style="@style/Text.NowMe.Body"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_nowme_visibility_menu_item"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/nowme_space_md"
        android:textColor="@color/nowme_text_primary"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="@dimen/nowme_space_sm"
        android:layout_marginVertical="@dimen/nowme_space_xs"
        android:background="@color/nowme_surface_overlay" />

    <TextView
        android:id="@+id/btnDeleteNowme"
        style="@style/Text.NowMe.Body"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_nowme_visibility_menu_item"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/nowme_space_md"
        android:text="Delete"
        android:textColor="@color/nowme_danger"
        android:textStyle="bold" />

</LinearLayout>
