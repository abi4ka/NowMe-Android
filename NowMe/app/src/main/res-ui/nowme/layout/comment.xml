<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Emoji -->
    <TextView
        android:id="@+id/tvEmoji"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="🐱"
        android:textSize="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Username -->
    <TextView
        android:id="@+id/tvUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="username"
        android:textColor="@color/nowme_text_muted"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/tvEmoji"
        app:layout_constraintTop_toTopOf="@id/tvEmoji"
        android:layout_marginStart="8dp"/>

    <!-- Comments-->
    <TextView
        android:id="@+id/tvComment"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Comment..."
        android:textColor="@color/nowme_text_primary"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="@id/tvUser"
        app:layout_constraintTop_toBottomOf="@id/tvUser"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
