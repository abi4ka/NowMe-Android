<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Text.NowMe.Display" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:textColor">@color/nowme_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.NowMe.Title" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:textColor">@color/nowme_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="Text.NowMe.Body" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:textColor">@color/nowme_text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Text.NowMe.Caption" parent="@android:style/TextAppearance">
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:textColor">@color/nowme_text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.NowMe.Button.Primary" parent="@android:style/Widget.Button">
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/nowme_accent_dark_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>
