<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.NowMe" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="actionBarStyle">@style/MyActionBar</item>
        <item name="windowActionBarOverlay">false</item>
        <item name="android:fontFamily">sans-serif-rounded</item>
        <item name="fontFamily">sans-serif-rounded</item>
        <item name="colorPrimary">@color/nowme_navy_900</item>
        <item name="colorPrimaryVariant">@color/nowme_navy_950</item>
        <item name="colorOnPrimary">@color/nowme_text_primary</item>
        <item name="colorSecondary">@color/nowme_accent</item>
        <item name="colorSecondaryVariant">@color/nowme_surface</item>
        <item name="colorOnSecondary">@color/nowme_accent_dark_text</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/nowme_navy_950</item>
        <item name="android:statusBarColor">@color/nowme_navy_950</item>
    </style>

    <style name="MyActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/nowme_navy_900</item>
    </style>

    <style name="Theme.NowMe.NoActionBar" parent="Theme.NowMe">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>
